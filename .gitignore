# ============================================================
# .gitignore — Snake Arena Monorepo
# ============================================================

# ── Node modules ─────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────────────────────────
client/dist/
server/dist/
shared/dist/

# ── Native addon build artifacts ──────────────────────────────
# Only ignore the server's native build directory
server/build/
# .node binaries (compiled native addons)
**/*.node
# Object and archive files
**/*.o
**/*.a

# ── Environment secrets ───────────────────────────────────────
.env
.env.local
.env.*.local
server/.env

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# ── IDE files ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── TypeScript cache ─────────────────────────────────────────
*.tsbuildinfo

# ── PM2 ──────────────────────────────────────────────────────
.pm2/

# ── Docker volumes ───────────────────────────────────────────
docker-volumes/
