{
  "name": "snake-arena-shared",
  "version": "1.0.0",
  "description": "Shared types and constants for Snake Arena",
  "main": "./dist/protocol.js",
  "types": "./dist/protocol.d.ts",
  "exports": {
    ".": {
      "require": "./dist/protocol.js",
      "types": "./dist/protocol.d.ts"
    },
    "./protocol": {
      "require": "./dist/protocol.js",
      "types": "./dist/protocol.d.ts"
    },
    "./constants": {
      "require": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "snake-arena-root": "file:.."
  }
}
