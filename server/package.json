{
  "name": "snake-arena-server",
  "version": "1.0.0",
  "description": "TypeScript WebSocket Authoritative Game Server",
  "main": "dist/server.js",
  "scripts": {
    "install": "node-gyp rebuild || node -e \"console.warn('Native addon build failed. Server will run in TS fallback mode.')\"",
    "build:addon": "node-gyp rebuild || node -e \"console.warn('Native addon build failed. Server will run in TS fallback mode.')\"",
    "build:ts": "tsc",
    "build": "npm run build:addon && npm run build:ts",
    "dev": "nodemon --watch \"src/**/*\" -e ts --exec \"ts-node\" src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@msgpack/msgpack": "^2.8.0",
    "express": "^4.19.2",
    "node-addon-api": "^8.8.0",
    "snake-arena-root": "file:..",
    "snake-arena-shared": "file:../shared",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/ws": "^8.5.10",
    "node-gyp": "^10.1.0",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
